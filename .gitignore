# UpStream Workspace Gitignore
# ==========================

# Environment variables containing sensitive API keys/secrets
.env
*.env
**/.env

# Python compilation and execution caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE / Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS generated files
Thumbs.db
EHthumbs_db
Desktop.ini
.DS_Store
